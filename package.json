{
  "name": "alarmind-desktop",
  "productName": "Alarmind",
  "version": "1.0.0",
  "description": "Alarmind desktop app — a dedicated window for your Alarmind dashboard.",
  "author": "Alarmind",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "in.alarmind.desktop",
    "productName": "Alarmind",
    "copyright": "Copyright © Alarmind",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "titlebar.html",
      "titlebar-preload.js",
      "screen-picker.html",
      "screen-picker-preload.js",
      "offline.html",
      "build/icon.png",
      "build/tray.png"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Alarmind",
      "artifactName": "Alarmind-Setup.exe",
      "include": "build/installer.nsh"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Education"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.education"
    }
  }
}
